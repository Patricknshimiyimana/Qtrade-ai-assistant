# REQUIRED: Groq Free-Tier API Key
# Claim an instant, free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# LiteLLM model string. Default below uses Groq's free tier.
# For a fully local, no-API setup install Ollama and use e.g.:
#   LLM_MODEL=ollama/llama3.2
LLM_MODEL=groq/openai/gpt-oss-120b